
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getGlobalRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getGlobalRole() == 'Admin';
    }

    function isMember(data) {
      return isSignedIn() && (isAdmin() || (data.members != null && data.members[request.auth.uid] != null));
    }

    // Ultimate Admin Access
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /workspaces/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
      
      match /notifications/{id} { allow read, write: if request.auth.uid == userId || isAdmin(); }
      match /timeEntries/{id} { allow read, write: if request.auth.uid == userId || isAdmin(); }
    }

    match /companies/{id} {
      allow read, write: if isSignedIn();
    }

    match /contacts/{id} {
      allow read, write: if isSignedIn();
    }

    match /pipelines/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /deals/{id} {
      allow read, write: if isSignedIn();
    }

    match /activityLogs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read: if isMember(resource.data) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isMember(resource.data) || isAdmin();
      allow delete: if isAdmin();

      match /milestones/{id} {
        allow read, write: if isMember(get(/databases/$(database)/documents/projects/$(projectId)).data) || isAdmin();
      }

      match /tasks/{taskId} {
        allow read, write: if isMember(get(/databases/$(database)/documents/projects/$(projectId)).data) || isAdmin();
        match /subtasks/{id} { allow read, write: if isMember(get(/databases/$(database)/documents/projects/$(projectId)).data) || isAdmin(); }
        match /comments/{id} { allow read, write: if isMember(get(/databases/$(database)/documents/projects/$(projectId)).data) || isAdmin(); }
        match /attachments/{id} { allow read, write: if isMember(get(/databases/$(database)/documents/projects/$(projectId)).data) || isAdmin(); }
      }
    }
  }
}
