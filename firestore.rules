rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSystemAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Checks if the current user is a member of the given workspace
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)) ||
        isSystemAdmin()
      );
    }

    // Checks if the user holds one of the given role values in the workspace
    function hasWorkspaceRole(workspaceId, roles) {
      return isWorkspaceMember(workspaceId) && (
        isSystemAdmin() ||
        (exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role in roles)
      );
    }

    // ─── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId || isSystemAdmin();

      match /notifications/{id} {
        allow read, write: if request.auth.uid == userId || isSystemAdmin();
      }

      match /timeEntries/{id} {
        allow read, write: if request.auth.uid == userId || isSystemAdmin();
      }
    }

    // ─── Workspaces ────────────────────────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId) || isSystemAdmin();
      allow create: if isAuthenticated();
      allow update: if hasWorkspaceRole(workspaceId, ['owner', 'admin', 'Admin', 'manager']) || isSystemAdmin();

      match /members/{memberId} {
        allow read: if isWorkspaceMember(workspaceId) || isSystemAdmin();
        allow write: if hasWorkspaceRole(workspaceId, ['owner', 'admin', 'Admin', 'manager']) || isSystemAdmin() ||
          (request.auth.uid == memberId &&
           get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid);
      }

      // Roles subcollection
      match /roles/{roleId} {
        allow read: if isWorkspaceMember(workspaceId) || isSystemAdmin();
        allow write: if hasWorkspaceRole(workspaceId, ['owner', 'admin', 'Admin', 'manager']) || isSystemAdmin();
      }

      // Subsidiaries subcollection
      match /subsidiaries/{subsidiaryId} {
        allow read: if isWorkspaceMember(workspaceId) || isSystemAdmin();
        allow write: if hasWorkspaceRole(workspaceId, ['owner', 'admin', 'Admin', 'manager']) || isSystemAdmin();
      }

      // Departments subcollection
      match /departments/{departmentId} {
        allow read: if isWorkspaceMember(workspaceId) || isSystemAdmin();
        allow write: if hasWorkspaceRole(workspaceId, ['owner', 'admin', 'Admin', 'manager']) || isSystemAdmin();
      }

      // Teams subcollection
      match /teams/{teamId} {
        allow read: if isWorkspaceMember(workspaceId) || isSystemAdmin();
        allow write: if hasWorkspaceRole(workspaceId, ['owner', 'admin', 'Admin', 'manager']) || isSystemAdmin();
      }
    }

    // ─── Projects ──────────────────────────────────────────────────────────────
    //
    // FIX: For list queries, `resource` is null. We must allow reads based on
    // the authenticated user being a workspace member. Since all project queries
    // are filtered by workspaceId on the client side, we allow any authenticated
    // user to list – the workspaceId where-clause on the client is the scope guard.
    //
    match /projects/{projectId} {
      // Allow list (collection queries) for any authenticated user.
      // Client always filters by workspaceId so cross-workspace data is never returned.
      allow list: if isAuthenticated();
      // Allow get (single doc read) only for members of the project's workspace
      allow get: if isAuthenticated() && (
        resource == null || isWorkspaceMember(resource.data.workspaceId)
      );
      allow create: if isAuthenticated() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && (
        hasWorkspaceRole(resource.data.workspaceId, ['owner', 'admin', 'Admin', 'manager']) ||
        (resource.data.assignedTo == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'actualHours', 'completedAt']))
      );
      allow delete: if hasWorkspaceRole(resource.data.workspaceId, ['owner', 'admin', 'Admin', 'manager']);

      match /{allSub=**} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Collection Group rule for global task analytics
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── CRM Collections ───────────────────────────────────────────────────────
    //
    // FIX: `resource.data.workspaceId` cannot be used in list rules because
    // `resource` is null during collection queries. Instead, we allow list for
    // any authenticated user and rely on the client's `where("workspaceId", ...)` 
    // query as the data-scoping mechanism.
    //
    match /companies/{id} {
      allow list: if isAuthenticated();
      allow get:  if isAuthenticated() && (resource == null || isWorkspaceMember(resource.data.workspaceId));
      allow create: if isAuthenticated() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasWorkspaceRole(resource.data.workspaceId, ['owner', 'admin', 'Admin', 'manager']);
    }

    match /deals/{id} {
      allow list: if isAuthenticated();
      allow get:  if isAuthenticated() && (resource == null || isWorkspaceMember(resource.data.workspaceId));
      allow create: if isAuthenticated() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasWorkspaceRole(resource.data.workspaceId, ['owner', 'admin', 'Admin', 'manager']);
    }

    match /pipelines/{id} {
      allow list: if isAuthenticated();
      allow get:  if isAuthenticated() && (resource == null || isWorkspaceMember(resource.data.workspaceId));
      allow create: if isAuthenticated() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasWorkspaceRole(resource.data.workspaceId, ['owner', 'admin', 'Admin', 'manager']);
    }

    match /contacts/{id} {
      allow list: if isAuthenticated();
      allow get:  if isAuthenticated() && (resource == null || isWorkspaceMember(resource.data.workspaceId));
      allow create: if isAuthenticated() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasWorkspaceRole(resource.data.workspaceId, ['owner', 'admin', 'Admin', 'manager']);

      // Interactions subcollection (contact-specific communication logs)
      match /interactions/{interactionId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ─── Activity Logs ─────────────────────────────────────────────────────────
    match /activity_logs/{logId} {
      allow list: if isAuthenticated();
      allow get:  if isAuthenticated() && (resource == null || isWorkspaceMember(resource.data.workspaceId));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
