
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getGlobalRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getGlobalRole() == 'Admin';
    }

    function isMember(data) {
      return isSignedIn() && (isAdmin() || (data.members != null && data.members[request.auth.uid] != null));
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
      
      match /notifications/{id} { allow read, write: if request.auth.uid == userId || isAdmin(); }
      match /timeEntries/{id} { allow read, write: if request.auth.uid == userId || isAdmin(); }
    }

    match /companies/{companyId} {
      allow read, write: if isSignedIn();
      match /contacts/{contactId} { allow read, write: if isSignedIn(); }
    }

    match /deals/{dealId} {
      allow read, write: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read: if isMember(resource.data) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isMember(resource.data) || isAdmin();
      allow delete: if isAdmin();

      match /tasks/{taskId} {
        allow read, write: if true; // Inherit parent logic in prod, simplified for proto
        match /subtasks/{id} { allow read, write: if true; }
        match /comments/{id} { allow read, write: if true; }
        match /attachments/{id} { allow read, write: if true; }
      }
      
      match /milestones/{milestoneId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
