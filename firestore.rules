
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getGlobalRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getGlobalRole() == 'Admin';
    }

    // Ultimate Admin Access - Recursive override for all collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /workspaces/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin() || request.auth.uid == userId;
      
      match /timeEntries/{id} { allow read, write: if request.auth.uid == userId || isAdmin(); }
      match /notifications/{id} { allow read, write: if request.auth.uid == userId || isAdmin(); }
    }

    match /contacts/{id} {
      allow read, write: if isSignedIn();
      match /interactions/{intId} { allow read, write: if isSignedIn(); }
    }

    match /companies/{id} {
      allow read, write: if isSignedIn();
    }

    match /deals/{id} {
      allow read, write: if isSignedIn();
    }

    match /projects/{id} {
      allow read, write: if isSignedIn();
      match /{allSub=**} { allow read, write: if isSignedIn(); }
    }

    match /activityLogs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
