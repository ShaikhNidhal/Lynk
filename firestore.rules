
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getGlobalRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getGlobalRole() == 'Admin';
    }

    function hasGlobalRole(role) {
      return isSignedIn() && getGlobalRole() == role;
    }

    function isProjectMember(data) {
      return isSignedIn() && (
        isAdmin() || 
        (data.members != null && data.members[request.auth.uid] != null)
      );
    }

    function isProjectOwner(data) {
      return isSignedIn() && (
        isAdmin() || 
        (data.members != null && data.members[request.auth.uid] == 'owner')
      );
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin());
      allow update: if (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      match /timeEntries/{entryId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /projects/{projectId} {
      allow get, list: if isProjectMember(resource.data) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isProjectMember(resource.data) || isAdmin();
      allow delete: if isProjectOwner(resource.data) || isAdmin();

      match /tasks/{taskId} {
        allow get, list: if isProjectMember(resource.data) || isAdmin();
        allow create: if (isProjectMember(request.resource.data) || isAdmin());
        allow update: if isProjectMember(resource.data) || isAdmin();
        allow delete: if isProjectMember(resource.data) || isAdmin();

        match /subtasks/{subtaskId} {
          allow get, list: if isProjectMember(resource.data) || isAdmin();
          allow create, update, delete: if isProjectMember(resource.data) || isAdmin();
        }

        match /comments/{commentId} {
          allow get, list: if isProjectMember(resource.data) || isAdmin();
          allow create, update, delete: if isProjectMember(resource.data) || isAdmin();
        }

        match /attachments/{attachmentId} {
          allow get, list: if isProjectMember(resource.data) || isAdmin();
          allow create, update, delete: if isProjectMember(resource.data) || isAdmin();
        }
      }
    }
  }
}
