
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SPRINTFLOW ACCESS CONTROL PHILOSOPHY
     * 
     * Core Philosophy:
     * This ruleset implements a hybrid security model combining User Ownership, Global Role-Based 
     * Access Control (RBAC), and Project-based Shared Access (Collaborators). 
     * 
     * Data Structure:
     * - /users/{userId}: Global user profiles containing system-wide roles (Admin, Project Manager, etc.).
     * - /projects/{projectId}: Collaborative containers using a 'members' map for authorization.
     * - Nested Resources: Tasks, Comments, and Attachments denormalize the project 'members' map 
     *   to ensure high-performance authorization without recursive database lookups.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Retrieves the global user profile to check system roles
    function getGlobalRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasGlobalRole(role) {
      return isSignedIn() && getGlobalRole() == role;
    }

    // Checks if the user is present in the document's denormalized members map
    function isProjectMember(data) {
      return isSignedIn() && data.members != null && data.members[request.auth.uid] != null;
    }

    function isProjectOwner(data) {
      return isSignedIn() && data.members != null && data.members[request.auth.uid] == 'owner';
    }

    // Validates that the data matches the path for relational integrity
    function matchesPath(field, pathId) {
      return field == pathId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. 
     * Any signed-in user can view other profiles for the Team Directory.
     * Only Admins, Project Managers, or the owner can create/update.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if (isOwner(userId) || hasGlobalRole('Admin') || hasGlobalRole('Project Manager')) && matchesPath(request.resource.data.id, userId);
      allow update: if (isOwner(userId) || hasGlobalRole('Admin')) && resource != null;
      allow delete: if hasGlobalRole('Admin') && resource != null;

      /**
       * @description Private user notifications.
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Collaborative projects.
     */
    match /projects/{projectId} {
      allow get, list: if isProjectMember(resource.data);
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] != null;
      allow update: if isProjectMember(resource.data) && resource != null;
      allow delete: if (isProjectOwner(resource.data) || hasGlobalRole('Admin')) && resource != null;

      /**
       * @description Tasks within a project.
       */
      match /tasks/{taskId} {
        allow get, list: if isProjectMember(resource.data);
        allow create: if isProjectMember(request.resource.data) && matchesPath(request.resource.data.projectId, projectId);
        allow update: if isProjectMember(resource.data) && matchesPath(request.resource.data.projectId, resource.data.projectId) && resource != null;
        allow delete: if isProjectMember(resource.data) && resource != null;

        /**
         * @description Subtasks of a task.
         */
        match /subtasks/{subtaskId} {
          allow get, list: if isProjectMember(resource.data);
          allow create: if isProjectMember(request.resource.data) && matchesPath(request.resource.data.taskId, taskId);
          allow update: if isProjectMember(resource.data) && matchesPath(request.resource.data.taskId, resource.data.taskId) && resource != null;
          allow delete: if isProjectMember(resource.data) && resource != null;
        }

        /**
         * @description Comments on tasks.
         */
        match /comments/{commentId} {
          allow get, list: if isProjectMember(resource.data);
          allow create: if isProjectMember(request.resource.data) && matchesPath(request.resource.data.authorId, request.auth.uid);
          allow update: if isProjectMember(resource.data) && matchesPath(resource.data.authorId, request.auth.uid) && resource != null;
          allow delete: if (isProjectMember(resource.data) && matchesPath(resource.data.authorId, request.auth.uid)) || hasGlobalRole('Admin');
        }

        /**
         * @description File attachments for tasks.
         */
        match /attachments/{attachmentId} {
          allow get, list: if isProjectMember(resource.data);
          allow create: if isProjectMember(request.resource.data) && matchesPath(request.resource.data.uploaderId, request.auth.uid);
          allow update: if isProjectMember(resource.data) && matchesPath(request.resource.data.uploaderId, request.auth.uid) && resource != null;
          allow delete: if (isProjectMember(resource.data) && matchesPath(request.resource.data.uploaderId, request.auth.uid)) || hasGlobalRole('Admin');
        }

        /**
         * @description Time tracking entries.
         */
        match /timeEntries/{timeEntryId} {
          allow get, list: if isProjectMember(resource.data);
          allow create: if isProjectMember(request.resource.data) && matchesPath(request.resource.data.userId, request.auth.uid);
          allow update: if isProjectMember(resource.data) && matchesPath(request.resource.data.userId, request.auth.uid) && resource != null;
          allow delete: if (isProjectMember(resource.data) && matchesPath(request.resource.data.userId, request.auth.uid)) || hasGlobalRole('Admin');
        }
      }
    }
  }
}
