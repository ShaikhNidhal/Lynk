
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and role data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Project Manager", "Team Member", "Client"] },
        "phoneNumber": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "notificationSettings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Company": {
      "title": "Company",
      "description": "Represents a client organization or partner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "website": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive"] },
        "healthScore": { "type": "number" },
        "address": { "type": "string" },
        "billingInfo": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Contact": {
      "title": "Contact",
      "description": "An individual associated with a Company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "jobTitle": { "type": "string" },
        "isPrimary": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Deal": {
      "title": "Deal",
      "description": "A sales opportunity in the pipeline.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string" },
        "probability": { "type": "number" },
        "expectedCloseDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Open", "Won", "Lost"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyId": { "type": "string" },
        "dealId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "budget": { "type": "number" },
        "members": { "type": "object" },
        "createdAt": { "type": "string" }
      }
    },
    "Milestone": {
      "title": "Milestone",
      "description": "A major phase or goal within a project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Completed", "Overdue"] },
        "color": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company" } },
      { "path": "/contacts/{contactId}", "definition": { "entityName": "Contact" } },
      { "path": "/deals/{dealId}", "definition": { "entityName": "Deal" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/projects/{projectId}/milestones/{milestoneId}", "definition": { "entityName": "Milestone" } }
    ]
  }
}
