
{
  "entities": {
    "Workspace": {
      "title": "Workspace",
      "description": "Multi-tenancy foundation for the organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "planType": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and role data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Project Manager", "Team Member", "Client"] },
        "phoneNumber": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "timezone": { "type": "string" },
        "notificationSettings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Company": {
      "title": "Company",
      "description": "Represents a client organization or partner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "sizeRange": { "type": "string" },
        "website": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive", "Churned"] },
        "healthScore": { "type": "number" },
        "lifetimeValue": { "type": "number" },
        "address": { "type": "object" },
        "billingInfo": { "type": "object" },
        "workspaceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "dealId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Planning", "Active", "On Hold", "Completed", "Cancelled"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] },
        "type": { "type": "string" },
        "budget": { "type": "number" },
        "budgetSpent": { "type": "number" },
        "healthStatus": { "type": "string", "enum": ["Good", "At Risk", "Critical"] },
        "startDate": { "type": "string", "format": "date" },
        "targetEndDate": { "type": "string", "format": "date" },
        "members": { "type": "object" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "Milestone": {
      "title": "Milestone",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Achieved", "Missed"] },
        "color": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "estimatedHours": { "type": "number" },
        "actualHours": { "type": "number" },
        "dueDate": { "type": "string" },
        "assignedToId": { "type": "string" },
        "position": { "type": "number" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/workspaces/{workspaceId}", "definition": { "entityName": "Workspace" } },
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/projects/{projectId}/milestones/{id}", "definition": { "entityName": "Milestone" } },
      { "path": "/projects/{projectId}/tasks/{taskId}", "definition": { "entityName": "Task" } }
    ]
  }
}
