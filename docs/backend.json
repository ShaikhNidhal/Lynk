
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the SprintFlow application, including their assigned role and personal details. Authentication and core user management (e.g., password storage) are handled by an external system (Firebase Authentication).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity. This typically corresponds to the Firebase Authentication User ID (UID)."
        },
        "firstName": {
          "type": "string",
          "description": "The user's first name."
        },
        "lastName": {
          "type": "string",
          "description": "The user's last name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for communication and identification within the app (not for authentication credentials, which are managed externally by Firebase Auth).",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "role": {
          "type": "string",
          "description": "The assigned role for the user, defining their access permissions within the application. Possible values include 'Admin', 'Project Manager', 'Team Member', 'Client'."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "An optional URL to the user's profile picture.",
          "format": "uri"
        },
        "notificationSettings": {
          "type": "object",
          "description": "User's notification preferences.",
          "properties": {
            "emailSummaries": { "type": "boolean" },
            "inAppAlerts": { "type": "boolean" },
            "securityAlerts": { "type": "boolean" }
          }
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "description": "A record of time spent on a specific project or task.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "taskId": { "type": "string" },
        "taskTitle": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "projectId", "duration", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/users/{userId}/timeEntries/{entryId}",
        "definition": {
          "entityName": "TimeEntry",
          "schema": {
            "$ref": "#/backend/entities/TimeEntry"
          },
          "description": "User-specific time logs for global tracking views."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Top-level collection for collaborative projects."
        }
      }
    ]
  }
}
