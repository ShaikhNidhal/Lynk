
{
  "entities": {
    "Workspace": {
      "title": "Workspace",
      "description": "Multi-tenancy foundation for the organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "planType": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and role data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Project Manager", "Team Member", "Client"] },
        "phoneNumber": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "timezone": { "type": "string" },
        "notificationSettings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Company": {
      "title": "Company",
      "description": "Represents a client organization or partner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "sizeRange": { "type": "string" },
        "website": { "type": "string" },
        "address": { "type": "object" },
        "billingInfo": { "type": "object" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive", "Churned"] },
        "healthScore": { "type": "number" },
        "lifetimeValue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "budget": { "type": "number" },
        "budgetSpent": { "type": "number" },
        "healthStatus": { "type": "string" },
        "startDate": { "type": "string" },
        "targetEndDate": { "type": "string" },
        "members": { "type": "object" },
        "createdAt": { "type": "string" }
      }
    },
    "Attachment": {
      "title": "Attachment",
      "description": "A file or document linked to an entity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "mimeType": { "type": "string" },
        "sizeBytes": { "type": "number" },
        "uploaderId": { "type": "string" },
        "members": { "type": "object" },
        "version": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "assignedToId": { "type": "string" },
        "estimatedHours": { "type": "number" },
        "actualHours": { "type": "number" },
        "dueDate": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "projectId": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "number" },
        "isBillable": { "type": "boolean" },
        "description": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/workspaces/{workspaceId}", "definition": { "entityName": "Workspace" } },
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/timeEntries/{id}", "definition": { "entityName": "TimeEntry" } },
      { "path": "/users/{userId}/notifications/{id}", "definition": { "entityName": "Notification" } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company" } },
      { "path": "/contacts/{id}", "definition": { "entityName": "Contact" } },
      { "path": "/pipelines/{id}", "definition": { "entityName": "Pipeline" } },
      { "path": "/deals/{id}", "definition": { "entityName": "Deal" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/projects/{projectId}/attachments/{id}", "definition": { "entityName": "Attachment" } },
      { "path": "/projects/{projectId}/milestones/{id}", "definition": { "entityName": "Milestone" } },
      { "path": "/projects/{projectId}/tasks/{taskId}", "definition": { "entityName": "Task" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/subtasks/{id}", "definition": { "entityName": "Task" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/comments/{id}", "definition": { "entityName": "Comment" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/attachments/{id}", "definition": { "entityName": "Attachment" } }
    ]
  }
}
