
{
  "entities": {
    "Workspace": {
      "title": "Workspace",
      "description": "Multi-tenancy foundation for the organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "planType": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and role data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Project Manager", "Team Member", "Client"] },
        "phoneNumber": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "timezone": { "type": "string" },
        "notificationSettings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Company": {
      "title": "Company",
      "description": "Represents a client organization or partner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "sizeRange": { "type": "string" },
        "website": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive", "Churned"] },
        "healthScore": { "type": "number" },
        "lifetimeValue": { "type": "number" },
        "address": { "type": "object" },
        "billingInfo": { "type": "object" },
        "workspaceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Contact": {
      "title": "Contact",
      "description": "An individual associated with a Company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "jobTitle": { "type": "string" },
        "department": { "type": "string" },
        "isPrimary": { "type": "boolean" },
        "linkedinUrl": { "type": "string" },
        "lastContactDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Pipeline": {
      "title": "Pipeline",
      "description": "Definition of sales stages.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "stages": { "type": "array", "items": { "type": "object" } },
        "isActive": { "type": "boolean" },
        "workspaceId": { "type": "string" }
      }
    },
    "Deal": {
      "title": "Deal",
      "description": "A sales opportunity in the pipeline.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "value": { "type": "number" },
        "currency": { "type": "string" },
        "stageId": { "type": "string" },
        "probability": { "type": "number" },
        "expectedCloseDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Open", "Won", "Lost", "Stalled"] },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyId": { "type": "string" },
        "dealId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "type": { "type": "string" },
        "budget": { "type": "number" },
        "budgetSpent": { "type": "number" },
        "healthStatus": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "targetEndDate": { "type": "string", "format": "date" },
        "members": { "type": "object" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string" }
      }
    },
    "Milestone": {
      "title": "Milestone",
      "description": "A significant point or event in a project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "completedDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Achieved", "Missed"] },
        "color": { "type": "string" },
        "deliverables": { "type": "array", "items": { "type": "string" } },
        "projectId": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "An individual piece of work within a project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "type": { "type": "string" },
        "position": { "type": "number" },
        "estimatedHours": { "type": "number" },
        "actualHours": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "assignedToId": { "type": "string" },
        "ownerId": { "type": "string" },
        "projectId": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Subtask": {
      "title": "Subtask",
      "description": "A smaller task nested under a main task.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "done"] },
        "taskId": { "type": "string" },
        "projectId": { "type": "string" }
      }
    },
    "Comment": {
      "title": "Comment",
      "description": "A textual remark left on an entity.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "mentions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Attachment": {
      "title": "Attachment",
      "description": "A file linked to an entity.",
      "type": "object",
      "properties": {
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "mimeType": { "type": "string" },
        "sizeBytes": { "type": "number" },
        "uploaderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "description": "Work log record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "duration": { "type": "number" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "isBillable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Audit trail for workspace actions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "changes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/workspaces/{workspaceId}", "definition": { "entityName": "Workspace" } },
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/timeEntries/{id}", "definition": { "entityName": "TimeEntry" } },
      { "path": "/users/{userId}/notifications/{id}", "definition": { "entityName": "object" } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company" } },
      { "path": "/contacts/{contactId}", "definition": { "entityName": "Contact" } },
      { "path": "/pipelines/{pipelineId}", "definition": { "entityName": "Pipeline" } },
      { "path": "/deals/{dealId}", "definition": { "entityName": "Deal" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/projects/{projectId}/milestones/{milestoneId}", "definition": { "entityName": "Milestone" } },
      { "path": "/projects/{projectId}/tasks/{taskId}", "definition": { "entityName": "Task" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/subtasks/{subtaskId}", "definition": { "entityName": "Subtask" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/comments/{commentId}", "definition": { "entityName": "Comment" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/attachments/{attachmentId}", "definition": { "entityName": "Attachment" } },
      { "path": "/activityLogs/{logId}", "definition": { "entityName": "ActivityLog" } },
      { "path": "/templates/{templateId}", "definition": { "entityName": "object" } }
    ]
  }
}
