
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and role data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Project Manager", "Team Member", "Client"] },
        "phoneNumber": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "notificationSettings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Company": {
      "title": "Company",
      "description": "Represents a client organization or partner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "website": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive"] },
        "healthScore": { "type": "number" },
        "address": { "type": "string" },
        "billingInfo": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Contact": {
      "title": "Contact",
      "description": "An individual associated with a Company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "jobTitle": { "type": "string" },
        "isPrimary": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Proposal": {
      "title": "Proposal",
      "description": "A formal offer sent to a client/company.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "companyId": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Accepted", "Rejected"] },
        "documentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Deal": {
      "title": "Deal",
      "description": "A sales opportunity in the pipeline.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string" },
        "probability": { "type": "number" },
        "expectedCloseDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Open", "Won", "Lost"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyId": { "type": "string" },
        "dealId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "budget": { "type": "number" },
        "members": { "type": "object" },
        "createdAt": { "type": "string" }
      }
    },
    "Budget": {
      "title": "Budget",
      "description": "Financial allocation for a specific project phase.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "spent": { "type": "number" },
        "category": { "type": "string" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "An individual piece of work within a project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "assignedToId": { "type": "string" },
        "ownerId": { "type": "string" },
        "projectId": { "type": "string" }
      }
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "description": "Work log record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "duration": { "type": "number" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/timeEntries/{id}", "definition": { "entityName": "TimeEntry" } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company" } },
      { "path": "/companies/{companyId}/proposals/{proposalId}", "definition": { "entityName": "Proposal" } },
      { "path": "/contacts/{contactId}", "definition": { "entityName": "Contact" } },
      { "path": "/deals/{dealId}", "definition": { "entityName": "Deal" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/projects/{projectId}/budgets/{budgetId}", "definition": { "entityName": "Budget" } },
      { "path": "/projects/{projectId}/tasks/{taskId}", "definition": { "entityName": "Task" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/timeEntries/{id}", "definition": { "entityName": "TimeEntry" } }
    ]
  }
}
