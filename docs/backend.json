
{
  "entities": {
    "Workspace": {
      "title": "Workspace",
      "description": "Multi-tenancy foundation for the organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "planType": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and role data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Project Manager", "Team Member", "Client"] },
        "phoneNumber": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "timezone": { "type": "string" },
        "notificationSettings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Company": {
      "title": "Company",
      "description": "Represents a client organization or partner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "sizeRange": { "type": "string" },
        "website": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive", "Churned"] },
        "healthScore": { "type": "number" },
        "lifetimeValue": { "type": "number" },
        "address": { "type": "object" },
        "billingInfo": { "type": "object" },
        "workspaceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Contact": {
      "title": "Contact",
      "description": "An individual associated with a Company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "jobTitle": { "type": "string" },
        "department": { "type": "string" },
        "isPrimary": { "type": "boolean" },
        "linkedinUrl": { "type": "string" },
        "lastContactDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Communication record with a contact.",
      "type": "object",
      "properties": {
        "contactId": { "type": "string" },
        "type": { "type": "string", "enum": ["Call", "Email", "Meeting", "Other"] },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "actorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Deal": {
      "title": "Deal",
      "description": "A sales opportunity in the pipeline.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "value": { "type": "number" },
        "currency": { "type": "string" },
        "stageId": { "type": "string" },
        "probability": { "type": "number" },
        "expectedCloseDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Open", "Won", "Lost", "Stalled"] },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyId": { "type": "string" },
        "dealId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "type": { "type": "string" },
        "budget": { "type": "number" },
        "budgetSpent": { "type": "number" },
        "healthStatus": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "targetEndDate": { "type": "string", "format": "date" },
        "members": { "type": "object" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string" }
      }
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "description": "Work log record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "duration": { "type": "number" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "isBillable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/workspaces/{workspaceId}", "definition": { "entityName": "Workspace" } },
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/timeEntries/{id}", "definition": { "entityName": "TimeEntry" } },
      { "path": "/contacts/{contactId}", "definition": { "entityName": "Contact" } },
      { "path": "/contacts/{contactId}/interactions/{id}", "definition": { "entityName": "Interaction" } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company" } },
      { "path": "/deals/{dealId}", "definition": { "entityName": "Deal" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/activityLogs/{logId}", "definition": { "entityName": "ActivityLog" } }
    ]
  }
}
